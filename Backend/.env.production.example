# Copy this file to Backend/.env.production on the EC2 server and fill the values.
# Never commit real production secrets.

# ---- Server ----
BACKEND_PORT=8082
FRONTEND_URL=https://export-navi-8ham.vercel.app
CORS_ALLOWED_ORIGINS=https://export-navi-8ham.vercel.app
AUTH_COOKIE_SECURE=true

# ---- MySQL container ----
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=exportnavi
MYSQL_USER=exportnavi
MYSQL_PASSWORD=change-this-app-db-password

# ---- JWT ----
# Use a long random value. Example command: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION=86400000

# ---- Google OAuth ----
GOOGLE_CLIENT_SECRET=change-this-google-client-secret

# ---- OpenAI / AI ----
OPENAI_API_KEY=change-this-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
AI_MAX_REQUESTS_PER_HOUR=20

# ---- Public data APIs ----
KOTRA_API_KEY=
KSURE_API_KEY=
YESTRADE_API_KEY=

# ---- Optional document/OCR ----
UPSTAGE_API_KEY=

# ---- Optional tracing ----
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=exportnavi
